@startuml "EsperaRojo"

class Usuario {
  - id : Long
  - nombre : String
  - correo : String
  - password : String

  + consultarRuta() : Ruta
  + consultarAforo() : Integer
  + realizarPago() : Pago
}

class Ruta {
  - id : Long
  - nombre : String
  - direccion : String

  + obtenerParaderos() : List<Paradero>
}

class Paradero {
  - id : Long
  - nombre : String
  - ubicacion : String

  + obtenerBuses() : List<Bus>
}

class Bus {
  - id : Long
  - placa : String
  - capacidadMaxima : Integer
  - aforoActual : Integer

  + calcularDisponibilidad() : Double
}

class Ubicacion {
  - id : Long
  - latitud : Double
  - longitud : Double
  - fechaRegistro : Date

  + calcularDistancia() : Double
}

class Recomendacion {
  - id : Long
  - descripcion : String

  + generar() : String
}

abstract class Notificacion {
  - id : Long
  - mensaje : String
  - fecha : Date

  + enviar() : void
}

class NotificacionLlegada
class NotificacionAforo

Notificacion <|-- NotificacionLlegada
Notificacion <|-- NotificacionAforo

class Pago {
  - id : Long
  - fechaPago : Date
  - monto : Decimal

  + procesarPago() : Boolean
}

class MetodoPago {
  - id : Long
  - nombre : String
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
}

Pago --> EstadoPago : uses

Usuario "1" --> "1" Ubicacion : comparte

Usuario "1" --> "0..*" Pago : realiza

Pago "1" --> "1" MetodoPago : utiliza

Usuario "1" --> "0..*" Notificacion : recibe

Usuario "1" --> "0..*" Recomendacion : consulta

Ruta "1" --> "1..*" Paradero : contiene

Ruta "1" --> "1..*" Bus : asigna

Paradero "1" --> "0..*" Bus : recibe

Recomendacion --> Ruta
Recomendacion --> Paradero

@enduml